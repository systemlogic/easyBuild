    "cpp": [("rules_cc", "0.2.22"), ("toolchains_llvm", "1.8.0")],
    "java": [("rules_java", "9.6.1")],
    "python": [("rules_python", "2.2.0")],
    "go": [("rules_go", "0.61.1")],
