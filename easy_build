  putStrLn ("Compiler: " ++ compilerName ++ " " ++ showVersion compilerVersion)
"""


def readme_haskell(ghc_version: str, default_platform: str) -> str:
    platform_list = "\n".join(f"  - {p}" for p in SUPPORTED_PLATFORMS)
    return f"""\
# easy_build: hermetic Haskell project (remote GHC via Bazel)

This project was scaffolded by `easy_build init --language=haskell`. It builds
with a GHC {ghc_version} distribution that Bazel downloads itself (via the
`rules_haskell` module's `haskell_toolchains.bindists` extension). Your system
GHC (`ghcup`, `stack`, a system package, ...) is never invoked -- only Bazel is
required on the host.

## Supported target platforms

{platform_list}

## Usage

```sh
# Uses the default --config for this host ({default_platform}):
bazel build //example/haskell:hello
bazel run   //example/haskell:hello
```

## Verifying no host GHC is used

```sh
bazel aquery --config={default_platform} 'mnemonic("HaskellBuildBinary", //example/haskell:hello)' | grep -A1 'Command Line'
```

The `ghc`/build tool path must be under `external/rules_haskell++...` or
`external/all_bindist_toolchains+.../` -- never a `ghcup`-managed install,
`/usr/lib/ghc*`, or a `stack`-managed toolchain.

### A known rough edge

The `haskell_toolchains.bindists` bzlmod extension used here is a less
battle-tested path than the rest of this scaffold: rules_haskell's own
canonical example workspace (`tweag/rules_haskell/examples`) is configured to
use a Nix toolchain instead of a bindist download. Run the verification
command above on your actual target OS/arch before depending on this in
production, and be ready to adjust the pinned GHC version if a bindist isn't
published for your platform.

## Files

- `//MODULE.bazel` (workspace root) -- declares the hermetic `rules_haskell`
  `haskell_toolchains` toolchain, in this language's
  `EASY_BUILD:BEGIN/END HASKELL` block.
- `//platforms/BUILD.bazel` -- the four target `platform()` definitions.
- `//.bazelrc` -- one `build:<platform>` config per target, defaulting to
  `{default_platform}` for this host (GHC itself needs no extra flags).
- `BUILD.bazel` / `Main.hs` (this directory) -- a sample `haskell_binary`
  (with `base` imported via `haskell_toolchain_library`) that prints its OS,
  arch, and compiler version.
"""


def cmd_init(args: argparse.Namespace) -> None:
    default_platform = args.platform or detect_host_platform()
    if default_platform not in SUPPORTED_PLATFORMS:
        raise SystemExit(
            f"error: unsupported --platform '{default_platform}'; "
            f"choose one of: {', '.join(SUPPORTED_PLATFORMS)}"
        )

    out_dir = Path(args.dir).resolve()
    config_path = out_dir / CONFIG_FILE
    config = json.loads(config_path.read_text()) if config_path.exists() else {"languages": {}}

    if args.language == "cpp":
        llvm_version = args.version or DEFAULT_LLVM_VERSION
        example_dir = out_dir / "example" / "cpp"
        write_file(example_dir / "BUILD.bazel", build_bazel_cpp(), args.force)
        if not (example_dir / "hello.cpp").exists() or args.force:
            write_file(example_dir / "hello.cpp", hello_cpp(), args.force)
        write_file(example_dir / "README.md", readme_cpp(llvm_version, default_platform), args.force)
        config["languages"]["cpp"] = {
            "version": llvm_version,
            "platform": default_platform,
            "toolchain": "toolchains_llvm",
            "dependencies": {},
        }

    elif args.language == "java":
        java_version = args.version or DEFAULT_JAVA_VERSION
        example_dir = out_dir / "example" / "java"
        write_file(example_dir / "BUILD.bazel", build_bazel_java(), args.force)
        if not (example_dir / "Hello.java").exists() or args.force:
            write_file(example_dir / "Hello.java", hello_java(), args.force)
        write_file(example_dir / "README.md", readme_java(default_platform, java_version), args.force)
        config["languages"]["java"] = {
            "version": java_version,
            "platform": default_platform,
            "toolchain": "rules_java",
            "dependencies": {},
        }

    elif args.language == "python":
        python_version = args.version or DEFAULT_PYTHON_VERSION
        example_dir = out_dir / "example" / "python"
        write_file(example_dir / "BUILD.bazel", build_bazel_python(), args.force)
        if not (example_dir / "hello.py").exists() or args.force:
            write_file(example_dir / "hello.py", hello_py(), args.force)
        if not (example_dir / "requirements.in").exists() or args.force:
            write_file(example_dir / "requirements.in", requirements_in(), args.force)
        if not (example_dir / "requirements_lock.txt").exists() or args.force:
            write_file(example_dir / "requirements_lock.txt", requirements_lock(), args.force)
        write_file(example_dir / "README.md", readme_python(default_platform, python_version), args.force)
        config["languages"]["python"] = {
            "version": python_version,
            "platform": default_platform,
            "toolchain": "rules_python",
            "dependencies": {"certifi": CERTIFI_VERSION},
        }

    elif args.language == "go":
        go_version = args.version or DEFAULT_GO_VERSION
        example_dir = out_dir / "example" / "go"
        write_file(example_dir / "BUILD.bazel", build_bazel_go(), args.force)
        if not (example_dir / "hello.go").exists() or args.force:
            write_file(example_dir / "hello.go", hello_go(), args.force)
        write_file(example_dir / "README.md", readme_go(go_version, default_platform), args.force)
        config["languages"]["go"] = {
            "version": go_version,
            "platform": default_platform,
            "toolchain": "rules_go",
            "dependencies": {},
        }

    elif args.language == "rust":
        rust_version = args.version or DEFAULT_RUST_VERSION
        example_dir = out_dir / "example" / "rust"
        write_file(example_dir / "BUILD.bazel", build_bazel_rust(), args.force)
        if not (example_dir / "main.rs").exists() or args.force:
            write_file(example_dir / "main.rs", hello_rust(), args.force)
        write_file(example_dir / "README.md", readme_rust(rust_version, default_platform), args.force)
        config["languages"]["rust"] = {
            "version": rust_version,
            "platform": default_platform,
            "toolchain": "rules_rust",
            "dependencies": {},
        }

    elif args.language == "kotlin":
        kotlin_version = args.version or DEFAULT_KOTLIN_VERSION
        jdk_version = config["languages"].get("java", {}).get("version", DEFAULT_JAVA_VERSION)
        example_dir = out_dir / "example" / "kotlin"
        write_file(example_dir / "BUILD.bazel", build_bazel_kotlin(), args.force)
        if not (example_dir / "Hello.kt").exists() or args.force:
            write_file(example_dir / "Hello.kt", hello_kotlin(), args.force)
        write_file(
            example_dir / "README.md", readme_kotlin(kotlin_version, jdk_version, default_platform), args.force
        )
        config["languages"]["kotlin"] = {
            "version": kotlin_version,
            "platform": default_platform,
            "toolchain": "rules_kotlin",
            "dependencies": {},
            "jdk_version": jdk_version,
        }

    elif args.language == "scala":
        scala_version = args.version or DEFAULT_SCALA_VERSION
        jdk_version = config["languages"].get("java", {}).get("version", DEFAULT_JAVA_VERSION)
        example_dir = out_dir / "example" / "scala"
        write_file(example_dir / "BUILD.bazel", build_bazel_scala(), args.force)
        if not (example_dir / "Hello.scala").exists() or args.force:
            write_file(example_dir / "Hello.scala", hello_scala(), args.force)
        write_file(
            example_dir / "README.md", readme_scala(scala_version, jdk_version, default_platform), args.force
        )
        config["languages"]["scala"] = {
            "version": scala_version,
            "platform": default_platform,
            "toolchain": "rules_scala",
            "dependencies": {},
            "jdk_version": jdk_version,
        }

    elif args.language == "haskell":
        ghc_version = args.version or DEFAULT_GHC_VERSION
        example_dir = out_dir / "example" / "haskell"
        write_file(example_dir / "BUILD.bazel", build_bazel_haskell(), args.force)
        if not (example_dir / "Main.hs").exists() or args.force:
            write_file(example_dir / "Main.hs", hello_haskell(), args.force)
        write_file(example_dir / "README.md", readme_haskell(ghc_version, default_platform), args.force)
        config["languages"]["haskell"] = {
            "version": ghc_version,
            "platform": default_platform,
            "toolchain": "rules_haskell",
            "dependencies": {},
        }

    else:
        raise SystemExit(f"error: unsupported --language '{args.language}'")

    # MODULE.bazel, .bazelrc, platforms/, and the root README are shared across
    # every configured language, so they're always fully regenerated from the
    # accumulated config -- this is what lets a later `init` for a different
    # language add to them instead of clobbering an earlier language's setup.
    write_file(out_dir / "platforms" / "BUILD.bazel", platforms_build(), True)
    write_file(out_dir / "MODULE.bazel", render_module_bazel(config), True)
    write_file(out_dir / ".bazelrc", render_bazelrc(config, default_platform), True)
    write_file(out_dir / "README.md", render_root_readme(config, default_platform), True)

    config_path.write_text(json.dumps(config, indent=2) + "\n")
    print(f"wrote {config_path}")

    print(f"\nDone. Default target platform for this host: {default_platform}")
    print(f"Next: bazel run //example/{args.language}:hello")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="easy_build",
        description=(
            "Scaffold a hermetic Bazel project "
            "(cpp, java, python, go, rust, kotlin, scala, or haskell; no host toolchain)."
        ),
        epilog="""\
example:
  # Autodetect host OS/arch (e.g. macos_aarch64 on Apple Silicon):
  ./easy_build init --language=cpp
  ./easy_build init --language=java
  ./easy_build init --language=python
  ./easy_build init --language=go
  ./easy_build init --language=rust
  ./easy_build init --language=kotlin
  ./easy_build init --language=scala
  ./easy_build init --language=haskell

  # Pin an explicit toolchain version and target platform:
  ./easy_build init --language=cpp     --version=20.1.7 --platform=linux_x86_64
  ./easy_build init --language=java    --version=21      --platform=linux_aarch64
  ./easy_build init --language=python  --version=3.12    --platform=macos_x86_64
  ./easy_build init --language=go      --version=1.26.5  --platform=linux_x86_64
  ./easy_build init --language=rust    --version=1.96.1  --platform=linux_aarch64
  ./easy_build init --language=kotlin  --version=2.4.0   --platform=macos_x86_64
  ./easy_build init --language=scala   --version=3.8.4   --platform=macos_aarch64
  ./easy_build init --language=haskell --version=9.6.5   --platform=linux_x86_64
""",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command", required=True)

    init = sub.add_parser("init", help="scaffold a new project in --dir (default: cwd)")
    init.add_argument(
        "--language",
        default="cpp",
        choices=SUPPORTED_LANGUAGES,
        help="project language (default: cpp)",
    )
    init.add_argument(
        "--version",
        default=None,
        help=(
            "toolchain version: LLVM/clang for cpp "
            f"(default: {DEFAULT_LLVM_VERSION}), JDK for java "
            f"(default: {DEFAULT_JAVA_VERSION}), CPython for python "
            f"(default: {DEFAULT_PYTHON_VERSION}), Go SDK for go "
            f"(default: {DEFAULT_GO_VERSION}), rustc/cargo for rust "
            f"(default: {DEFAULT_RUST_VERSION}), kotlinc for kotlin "
            f"(default: {DEFAULT_KOTLIN_VERSION}), Scala compiler for scala "
            f"(default: {DEFAULT_SCALA_VERSION}), or GHC for haskell "
            f"(default: {DEFAULT_GHC_VERSION})"
        ),
    )
    init.add_argument(
        "--platform",
        default=None,
        choices=sorted(SUPPORTED_PLATFORMS),
        help="target platform (default: autodetect from host OS/arch)",
    )
    init.add_argument("--dir", default=".", help="directory to scaffold into (default: current directory)")
    init.add_argument("--force", action="store_true", help="overwrite existing files unconditionally")
    init.set_defaults(func=cmd_init)

    return parser


def main(argv=None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    args.func(args)
    return 0


if __name__ == "__main__":
    sys.exit(main())
