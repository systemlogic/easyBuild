}


def render_module_bazel(config: dict) -> str:
    languages = config["languages"]
    lines = [
        "module(",
        '    name = "easy_build_project",',
        '    version = "0.1.0",',
        ")",
        "",
        'bazel_dep(name = "platforms", version = "1.1.0")',
    ]
    for lang in SUPPORTED_LANGUAGES:
        if lang in languages:
            for dep_name, dep_version in LANGUAGE_BAZEL_DEPS[lang]:
                lines.append(f'bazel_dep(name = "{dep_name}", version = "{dep_version}")')
    blocks = [
        MODULE_BAZEL_BLOCK_BUILDERS[lang](languages[lang])
        for lang in SUPPORTED_LANGUAGES
        if lang in languages
    ]
    return "\n".join(lines) + "\n\n" + "\n".join(blocks)


