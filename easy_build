def build_bazel_python() -> str:
    return """\
load("@pip//:requirements.bzl", "requirement")
load("@rules_python//python:defs.bzl", "py_binary")
load("@rules_python//python:pip.bzl", "compile_pip_requirements")
load("@rules_python//python/zipapp:py_zipapp_binary.bzl", "py_zipapp_binary")

# `bazel run //example/python:requirements.update` regenerates
# requirements_lock.txt (with hashes) from requirements.in using the hermetic
# interpreter's pip.
compile_pip_requirements(
    name = "requirements",
    src = "requirements.in",
    requirements_txt = "requirements_lock.txt",
)

py_binary(
    name = "hello_lib",
    srcs = ["hello.py"],
    main = "hello.py",
    deps = [requirement("certifi")],
)

# Packages hello_lib as a single self-executable zipapp: the hermetic
# interpreter, stdlib, and resolved pip wheels are all bundled inside, so
# bazel-bin/example/python/hello.pyz runs standalone on a matching target
# machine.
py_zipapp_binary(
    name = "hello",
    binary = ":hello_lib",
)
"""


