def detect_host_platform() -> str:
    system = host_platform.system().lower()
    machine = host_platform.machine().lower()
    os_name = {"darwin": "macos", "linux": "linux"}.get(system)
    cpu = {"x86_64": "x86_64", "amd64": "x86_64", "arm64": "aarch64", "aarch64": "aarch64"}.get(machine)
    if os_name is None or cpu is None:
        raise SystemExit(
            f"error: unsupported host ({system}/{machine}); "
            f"pass --platform explicitly, one of: {', '.join(SUPPORTED_PLATFORMS)}"
        )
    return f"{os_name}_{cpu}"


def platform_config_lines() -> list:
    return [f"build:{name} --platforms=//platforms:{name}" for name in SUPPORTED_PLATFORMS]


def platforms_build() -> str:
    lines = [
        "# Target platform definitions for hermetic cross-arch builds.",
        "",
    ]
    for name, (os_c, cpu_c) in SUPPORTED_PLATFORMS.items():
        lines.append("platform(")
        lines.append(f'    name = "{name}",')
        lines.append("    constraint_values = [")
        lines.append(f'        "{os_c}",')
        lines.append(f'        "{cpu_c}",')
        lines.append("    ],")
        lines.append(")")
        lines.append("")
    return "\n".join(lines)


def write_file(path: Path, content: str, force: bool) -> None:
    if path.exists() and not force:
        existing = path.read_text()
        if existing == content:
            return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)
    print(f"wrote {path}")


# ============================================================================
# MODULE.bazel / .bazelrc: shared, composed from every configured language
# ============================================================================

def module_bazel_cpp_block(llvm_version: str) -> str:
    return f"""\
# === EASY_BUILD:BEGIN CPP ===
# Hermetic clang/LLVM toolchain. Bazel downloads this pinned distribution and
# uses it exclusively -- no host gcc/clang/Xcode/MSVC is consulted.
llvm = use_extension("@toolchains_llvm//toolchain/extensions:llvm.bzl", "llvm")
llvm.toolchain(
    name = "llvm_toolchain",
    llvm_version = "{llvm_version}",
)
use_repo(llvm, "llvm_toolchain")

register_toolchains(
    "@llvm_toolchain//:all",
)
# === EASY_BUILD:END CPP ===
"""


def module_bazel_java_block() -> str:
    return """\
# === EASY_BUILD:BEGIN JAVA ===
# rules_java registers a remotejdk_<version> distribution for every supported
# platform in its own MODULE.bazel -- no extension call is needed here to get
# them, just the bazel_dep above. It also registers a `local_jdk` toolchain
# (the host's JAVA_HOME/`java`) as a fallback, so pinning
# --java_runtime_version / --tool_java_runtime_version in .bazelrc (see below)
# is what actually forces Bazel to use the downloaded JDK exclusively.
# === EASY_BUILD:END JAVA ===
"""


def module_bazel_python_block(python_version: str) -> str:
    python_version_us = python_version.replace(".", "_")
    return f"""\
# === EASY_BUILD:BEGIN PYTHON ===
# Hermetic CPython toolchain. Bazel downloads a standalone, prebuilt CPython
# {python_version} distribution (python-build-standalone) for each target
# platform below and uses it exclusively -- the host's `python3` (pyenv,
# Homebrew, /usr/bin/python3, ...) is never consulted.
python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(
    python_version = "{python_version}",
    is_default = True,
)
use_repo(python, "python_{python_version_us}")

# pip configuration: direct dependencies go in example/python/requirements.in;
# run `bazel run //example/python:requirements.update` to (re)generate the
# hash-pinned requirements_lock.txt below, which pip.parse resolves against
# the hermetic interpreter (never the host's pip).
pip = use_extension("@rules_python//python/extensions:pip.bzl", "pip")
pip.parse(
    hub_name = "pip",
    python_version = "{python_version}",
    requirements_lock = "//example/python:requirements_lock.txt",
)
use_repo(pip, "pip")
# === EASY_BUILD:END PYTHON ===
"""


def module_bazel_go_block(go_version: str) -> str:
    return f"""\
# === EASY_BUILD:BEGIN GO ===
# Hermetic Go SDK. go_sdk.download resolves version {go_version} against
# https://go.dev/dl/?mode=json (Go's own official release index, fetched at
# build time) and downloads a prebuilt SDK for the target platform -- no host
# `go` (GOROOT, a Homebrew/apt Go, ...) is ever consulted.
go_sdk = use_extension("@rules_go//go:extensions.bzl", "go_sdk")
go_sdk.download(version = "{go_version}")
use_repo(go_sdk, "go_toolchains")

register_toolchains(
    "@go_toolchains//:all",
)
# === EASY_BUILD:END GO ===
"""


def module_bazel_rust_block(rust_version: str) -> str:
    return f"""\
# === EASY_BUILD:BEGIN RUST ===
# Hermetic Rust toolchain. rust.toolchain downloads a prebuilt rustc/cargo
# distribution for version {rust_version} from static.rust-lang.org for the
# target platform -- no host `rustc`/`cargo` (rustup, a system package, ...)
# is ever consulted.
rust = use_extension("@rules_rust//rust:extensions.bzl", "rust")
rust.toolchain(
    edition = "2021",
    versions = ["{rust_version}"],
)
use_repo(rust, "rust_toolchains")

register_toolchains(
    "@rust_toolchains//:all",
)
# === EASY_BUILD:END RUST ===
"""


def module_bazel_kotlin_block() -> str:
    return """\
# === EASY_BUILD:BEGIN KOTLIN ===
# Hermetic Kotlin compiler. rules_kotlin's own bzlmod extension downloads its
# pinned kotlinc/ksp distributions -- no host `kotlinc` is ever consulted.
# Kotlin compiles to JVM bytecode, so it also needs a JDK to run on; see the
# EASY_BUILD:BEGIN/END KOTLIN block in .bazelrc, which pins a hermetic
# remotejdk of its own so `kt_jvm_binary` never falls back to a host JDK,
# whether or not `easy_build init --language=java` was also run.
kotlin_repositories = use_extension(
    "@rules_kotlin//src/main/starlark/core/repositories:bzlmod_setup.bzl",
    "rules_kotlin_extensions",
)
use_repo(kotlin_repositories, "com_github_jetbrains_kotlin", "com_github_google_ksp")
# === EASY_BUILD:END KOTLIN ===
"""


def module_bazel_scala_block(scala_version: str) -> str:
    return f"""\
# === EASY_BUILD:BEGIN SCALA ===
# Hermetic Scala toolchain. scala_deps.scala() downloads the {scala_version}
# compiler/library artifacts -- no host `scalac` is ever consulted. Scala also
# compiles to JVM bytecode: like Kotlin, its block in .bazelrc pins its own
# hermetic remotejdk independently of whether `java` was also configured.
scala_config = use_extension(
    "@rules_scala//scala/extensions:config.bzl",
    "scala_config",
)
scala_config.settings(
    scala_version = "{scala_version}",
)
use_repo(scala_config, "rules_scala_config")

scala_deps = use_extension(
    "@rules_scala//scala/extensions:deps.bzl",
    "scala_deps",
)
scala_deps.scala()
# === EASY_BUILD:END SCALA ===
"""


def module_bazel_haskell_block(ghc_version: str) -> str:
    return f"""\
# === EASY_BUILD:BEGIN HASKELL ===
# Hermetic GHC toolchain. haskell_toolchains.bindists downloads a prebuilt GHC
# {ghc_version} distribution for the target platform -- no host `ghc` (ghcup,
# stack, a system package, ...) is ever consulted.
#
# KNOWN ROUGH EDGE: rules_haskell's own canonical example
# (tweag/rules_haskell/examples) uses a Nix toolchain rather than bindists, so
# this bzlmod-only bindist path is less battle-tested. Run the verification
# commands in example/haskell/README.md on your actual target OS/arch before
# depending on this in production.
haskell_toolchains = use_extension(
    "@rules_haskell//extensions:haskell_toolchains.bzl",
    "haskell_toolchains",
)
haskell_toolchains.bindists(
    version = "{ghc_version}",
)
use_repo(haskell_toolchains, "all_bindist_toolchains")

register_toolchains(
    "@all_bindist_toolchains//:all",
)
# === EASY_BUILD:END HASKELL ===
"""


