def render_bazelrc(config: dict, default_platform: str) -> str:
    languages = config["languages"]
    lines = [
        "# Target platform definitions (shared across all configured languages).",
    ]
    lines.extend(platform_config_lines())
    lines.append("")
    lines.append(f"build --config={default_platform}")
    lines.append("")
    blocks = [
        BAZELRC_BLOCK_BUILDERS[lang](languages[lang])
        for lang in SUPPORTED_LANGUAGES
        if lang in languages
    ]
    return "\n".join(lines) + "\n" + "\n".join(blocks)


def render_root_readme(config: dict, default_platform: str) -> str:
    languages = config["languages"]
    lines = [
        "# easy_build: hermetic multi-language Bazel workspace",
        "",
        "This workspace is scaffolded by `easy_build init --language=<lang>`, where",
        f"`<lang>` is one of: {', '.join(SUPPORTED_LANGUAGES)}.",
        "Every configured language shares one `MODULE.bazel` and one `.bazelrc`",
        "(each language owns a marked `EASY_BUILD:BEGIN/END` block in both), and",
        "gets its own sample program under `example/<language>/`. Running `init`",
        "for a new language adds its block/example rather than replacing an",
        "existing language's.",
        "",
        "## Configured languages",
        "",
    ]
    configured = [lang for lang in SUPPORTED_LANGUAGES if lang in languages]
    if not configured:
        lines.append(f"_(none yet -- run `easy_build init --language={SUPPORTED_LANGUAGES[0]}`)_")
    for lang in configured:
        info = languages[lang]
        lines.append(
            f"- **{lang}** (v{info['version']}) -- `example/{lang}/README.md`, "
            f"`bazel run //example/{lang}:hello`"
        )
    lines.append("")
    lines.append(f"Default target platform for this host: `{default_platform}`")
    lines.append("")
    lines.append("## Files")
    lines.append("")
    lines.append("- `MODULE.bazel` / `.bazelrc` -- shared toolchain registration and")
    lines.append("  flags, one marked block per configured language.")
    lines.append("- `platforms/BUILD.bazel` -- the four target `platform()` definitions.")
    lines.append("- `example/<language>/` -- that language's sample program, `BUILD.bazel`,")
    lines.append("  and its own `README.md` with language-specific usage/verification steps.")
    lines.append("")
    return "\n".join(lines)


